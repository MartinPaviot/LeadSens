{
  "name": "leadsens-monorepo",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @leadsens/leads dev",
    "dev:elevay": "pnpm --filter @leadsens/elevay dev",
    "dev:all": "pnpm --parallel --filter './apps/*' dev",
    "build": "pnpm --filter @leadsens/leads build",
    "build:elevay": "pnpm --filter @leadsens/elevay build",
    "build:all": "pnpm --parallel --filter './apps/*' build",
    "typecheck": "pnpm --filter @leadsens/leads typecheck",
    "typecheck:all": "pnpm -r typecheck",
    "test": "pnpm --filter @leadsens/leads test",
    "lint": "pnpm --filter @leadsens/leads lint",
    "db:generate": "pnpm --filter @leadsens/db db:generate",
    "db:push": "pnpm --filter @leadsens/db db:push",
    "db:migrate": "pnpm --filter @leadsens/db db:migrate",
    "db:studio": "pnpm --filter @leadsens/db db:studio"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "@prisma/client",
      "prisma",
      "sharp",
      "unrs-resolver",
      "msgpackr-extract"
    ]
  }
}
