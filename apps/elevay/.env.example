# Copier ce fichier en .env et remplir les valeurs
# Ne JAMAIS committer le fichier .env avec des valeurs réelles

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host-pooler.neon.tech/dbname?sslmode=require&pgbouncer=true
DIRECT_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Better Auth
BETTER_AUTH_SECRET=your-secret-key-min-32-chars
BETTER_AUTH_URL=http://localhost:3001

# Google OAuth + APIs
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxx
YOUTUBE_API_KEY=AIzaSy-xxxxxxxxxxxx
GOOGLE_MAPS_KEY=AIzaSy-xxxxxxxxxxxx
GOOGLE_PAGESPEED_API_KEY=AIzaSy-xxxxxxxxxxxx
GOOGLE_VISION_API_KEY=AIzaSy-xxxxxxxxxxxx
GOOGLE_NLP_API_KEY=AIzaSy-xxxxxxxxxxxx
GOOGLE_MY_BUSINESS_BUSINESS_INFORMATION_API=AIzaSy-xxxxxxxxxxxx

# LLM (Anthropic Claude)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxx

# App
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Composio (social OAuth orchestration)
COMPOSIO_API_KEY=ak_xxxxxxxxxxxx
COMPOSIO_LINKEDIN_AUTH_CONFIG_ID=ac_xxxxxxxxxxxx
COMPOSIO_LINKEDIN_COMMUNITY_AUTH_CONFIG_ID=ac_xxxxxxxxxxxx
COMPOSIO_AHREFS_AUTH_CONFIG_ID=ac_xxxxxxxxxxxx
COMPOSIO_SEMRUSH_AUTH_CONFIG_ID=ac_xxxxxxxxxxxx
COMPOSIO_SLACK_AUTH_CONFIG_ID=ac_xxxxxxxxxxxx
COMPOSIO_SHOPIFY_AUTH_CONFIG_ID=ac_xxxxxxxxxxxx
COMPOSIO_HUBSPOT_AUTH_CONFIG_ID=ac_xxxxxxxxxxxx
COMPOSIO_SHEETS_AUTH_CONFIG_ID=ac_xxxxxxxxxxxx
COMPOSIO_GA_AUTH_CONFIG_ID=ac_xxxxxxxxxxxx
COMPOSIO_GSC_AUTH_CONFIG_ID=ac_xxxxxxxxxxxx

# Apify (social scraping fallback)
APIFY_TOKEN=apify_api_xxxxxxxxxxxx
APIFY_TASK_INSTAGRAM=xxxxxxxxxxxx
APIFY_TASK_TWITTER=xxxxxxxxxxxx
APIFY_TASK_TIKTOK=xxxxxxxxxxxx
APIFY_TASK_LINKEDIN=xxxxxxxxxxxx
APIFY_TASK_FACEBOOK=xxxxxxxxxxxx
APIFY_TASK_TRUSTPILOT=xxxxxxxxxxxx
APIFY_TASK_INFLUENCERS=xxxxxxxxxxxx

# Data APIs
SERPAPI_KEY=xxxxxxxxxxxx
DATAFORSEO_LOGIN=your-email@example.com
DATAFORSEO_PASSWORD=xxxxxxxxxxxx
GNEWS_API_KEY=xxxxxxxxxxxx

# Cache (Upstash Redis)
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxx

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Web scraping (Firecrawl)
FIRECRAWL_API_KEY=fc-xxxxxxxxxxxx

# Webhook security (SMI-20 Social Interaction Manager)
SMI_WEBHOOK_SECRET=your-webhook-secret-min-32-chars

# Sentry (error monitoring)
SENTRY_DSN=https://your-dsn@sentry.io/project-id
SENTRY_ORG=elevay-lt
SENTRY_PROJECT=javascript-nextjs
SENTRY_AUTH_TOKEN=your-sentry-auth-token
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/project-id

# Encryption (OAuth token encryption at rest)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=generate-64-hex-chars-with-command-above
