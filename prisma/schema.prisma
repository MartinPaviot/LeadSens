generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  name          String?
  emailVerified Boolean    @default(false)
  image         String?
  workspaceId   String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  accounts      Account[]
  sessions      Session[]
  workspace     Workspace? @relation(fields: [workspaceId], references: [id])

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

model Workspace {
  id             String          @id @default(cuid())
  name           String
  slug           String          @unique
  companyUrl     String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  companyDna     Json?
  agentFeedbacks AgentFeedback[]
  agentMemories  AgentMemory[]
  aiEvents       AIEvent[]
  campaigns      Campaign[]
  conversations  Conversation[]
  integrations   Integration[]
  leads          Lead[]
  replyThreads   ReplyThread[]
  users          User[]

  @@map("workspace")
}

model Integration {
  id           String            @id @default(cuid())
  workspaceId  String
  type         IntegrationType
  apiKey       String?
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  accountEmail String?
  accountName  String?
  status       IntegrationStatus @default(ACTIVE)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  workspace    Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, type])
  @@map("integration")
}

model Conversation {
  id          String    @id @default(cuid())
  workspaceId String
  title       String?
  campaignId  String?   @unique
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  campaign    Campaign? @relation(fields: [campaignId], references: [id])
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  messages    Message[]

  @@map("conversation")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String
  toolName       String?
  toolInput      Json?
  toolOutput     Json?
  componentName  String?
  componentProps Json?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("message")
}

model Lead {
  id              String         @id @default(cuid())
  workspaceId     String
  email           String
  firstName       String?
  lastName        String?
  company         String?
  jobTitle        String?
  linkedinUrl     String?
  phone           String?
  website         String?
  country         String?
  companySize     String?
  industry        String?
  instantlyLeadId String?
  instantlyListId String?
  enrichmentData  Json?
  enrichedAt      DateTime?
  icpScore        Int?
  icpBreakdown    Json?
  campaignId      String?
  crmContactId    String?
  verificationStatus String?    // null=unverified, valid/invalid/catch_all/unknown/spamtrap/abuse/disposable
  status          LeadStatus     @default(SOURCED)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  companyDomain   String?

  // Flat enrichment columns (CSV-ready, derived from enrichmentData JSON)
  companyPositioning String?
  companyOneLiner    String?
  companyDescription String?
  painPointsFlat     String?
  productsFlat       String?
  valueProp          String?
  targetCustomers    String?
  buyingSignals      String?
  techStackFlat      String?
  linkedinHeadline   String?
  careerHistory      String?
  recentPosts        String?
  emails          DraftedEmail[]
  performance     EmailPerformance[]
  replyThreads    ReplyThread[]
  campaign        Campaign?      @relation(fields: [campaignId], references: [id])
  workspace       Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, email])
  @@index([campaignId, status])
  @@map("lead")
}

model Campaign {
  id                  String         @id @default(cuid())
  workspaceId         String
  name                String
  status              CampaignStatus @default(DRAFT)
  icpDescription      String
  icpFilters          Json
  tone                String?
  stepsCount          Int            @default(6)
  instantlyCampaignId String?
  instantlyListId     String?
  leadsTotal          Int            @default(0)
  leadsScored         Int            @default(0)
  leadsEnriched       Int            @default(0)
  leadsDrafted        Int            @default(0)
  leadsPushed         Int            @default(0)
  leadsSkipped        Int            @default(0)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  angle               Json?

  // Analytics sync
  lastSyncedAt        DateTime?
  analyticsCache      Json?

  workspace           Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversation        Conversation?
  draftedEmails       DraftedEmail[]
  leads               Lead[]
  performance         EmailPerformance[]
  stepAnalytics       StepAnalytics[]
  replyThreads        ReplyThread[]

  @@map("campaign")
}

model DraftedEmail {
  id              String   @id @default(cuid())
  leadId          String
  campaignId      String
  step            Int
  subject         String
  subjectVariants Json?
  body            String
  model           String
  tokensUsed      Int?
  qualityScore    Int?
  approved        Boolean  @default(false)
  userEdit        String?
  createdAt       DateTime @default(now())

  // Metadata for correlation (Phase D feedback loop)
  signalType      String?  // "leadership_change", "funding", "hiring", etc.
  signalCount     Int      @default(0)
  frameworkName   String?  // "PAS (Timeline Hook)", "Value-add", "Social Proof", etc.
  enrichmentDepth String?  // "rich" | "partial" | "minimal" | "none"
  bodyWordCount   Int?
  leadIndustry    String?  // denormalized for fast queries

  campaign        Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  lead            Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([leadId, step])
  @@map("drafted_email")
}

model CompanyCache {
  id        String   @id @default(cuid())
  domain    String   @unique
  markdown  String?  @db.Text
  scrapedAt DateTime @default(now())

  @@map("company_cache")
}

model AgentMemory {
  id          String         @id @default(cuid())
  workspaceId String
  key         String
  value       String
  category    MemoryCategory
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, key])
  @@map("agent_memory")
}

model AgentFeedback {
  id             String       @id @default(cuid())
  workspaceId    String
  type           FeedbackType
  originalOutput String
  userEdit       String?
  metadata       Json?
  createdAt      DateTime     @default(now())
  workspace      Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@map("agent_feedback")
}

model AIEvent {
  id          String    @id @default(cuid())
  workspaceId String
  provider    String    @default("mistral")
  model       String
  action      String
  tokensIn    Int
  tokensOut   Int
  cost        Float
  latencyMs   Int
  metadata    Json?
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@map("ai_event")
}

model EmailPerformance {
  id              String    @id @default(cuid())
  leadId          String
  campaignId      String
  email           String

  openCount       Int       @default(0)
  replyCount      Int       @default(0)
  clickCount      Int       @default(0)
  bounced         Boolean   @default(false)
  unsubscribed    Boolean   @default(false)
  interestStatus  Int?

  firstOpenAt     DateTime?
  lastOpenAt      DateTime?
  repliedAt       DateTime?
  replyIsAutoReply Boolean  @default(false)
  replyAiInterest Float?

  syncedAt        DateTime  @default(now())

  lead            Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  campaign        Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([leadId, campaignId])
  @@index([campaignId])
  @@map("email_performance")
}

model StepAnalytics {
  id          String   @id @default(cuid())
  campaignId  String
  step        Int

  sent        Int      @default(0)
  opened      Int      @default(0)
  replied     Int      @default(0)
  bounced     Int      @default(0)
  openRate    Float?
  replyRate   Float?

  syncedAt    DateTime @default(now())

  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, step])
  @@map("step_analytics")
}

model ReplyThread {
  id              String   @id @default(cuid())
  workspaceId     String
  leadId          String
  campaignId      String
  instantlyThreadId String?
  subject         String?
  status          ReplyThreadStatus @default(OPEN)
  interestScore   Float?
  classifiedAt    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lead            Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  campaign        Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  replies         Reply[]

  @@unique([leadId, campaignId])
  @@index([workspaceId, status])
  @@map("reply_thread")
}

model Reply {
  id          String      @id @default(cuid())
  threadId    String
  direction   ReplyDirection
  fromEmail   String
  toEmail     String
  subject     String?
  body        String
  preview     String?
  instantlyEmailId String?
  isAutoReply Boolean     @default(false)
  aiInterest  Float?
  sentAt      DateTime
  createdAt   DateTime    @default(now())

  thread      ReplyThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, sentAt])
  @@map("reply")
}

enum ReplyThreadStatus {
  OPEN
  INTERESTED
  NOT_INTERESTED
  MEETING_BOOKED
  CLOSED
}

enum ReplyDirection {
  INBOUND
  OUTBOUND
}

enum IntegrationType {
  INSTANTLY
  HUBSPOT
  APOLLO
  ZEROBOUNCE
  SMARTLEAD
  LEMLIST
  SALESFORCE
  GOOGLE_SHEETS
}

enum IntegrationStatus {
  ACTIVE
  ERROR
  EXPIRED
  DISCONNECTED
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

enum LeadStatus {
  SOURCED
  SCORED
  ENRICHED
  DRAFTED
  PUSHED
  SKIPPED
  // Post-launch statuses
  SENT
  REPLIED
  INTERESTED
  NOT_INTERESTED
  MEETING_BOOKED
  BOUNCED
  UNSUBSCRIBED
}

enum CampaignStatus {
  DRAFT
  SOURCING
  SCORING
  ENRICHING
  DRAFTING
  READY
  PUSHED
  ACTIVE
}

enum MemoryCategory {
  GENERAL
  COMPANY_CONTEXT
  ICP_HISTORY
  STYLE
}

enum FeedbackType {
  THUMBS_UP
  THUMBS_DOWN
  USER_EDIT
}
