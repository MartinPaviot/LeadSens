# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# root .claude/ — only settings.local.json lives here, everything else goes in apps/leads/.claude/
/.claude/settings.local.json
/.claude/commands/
/.claude/tasks/
/.claude/skills/
/.claude/findings/
/.claude/research/
/.claude/chat-audit/
/.claude/lp-research/
/.claude/integration-tests/
/.claude/progress.txt
/.claude/loop-log.txt

# screenshots (keep in .claude/findings/screenshots/ per app, not at root)
/*.png

# playwright MCP logs & screenshots
.playwright-mcp/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (per-app: apps/leads/.env, apps/elevay/.env)
.env
.env.*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.env.vercel
